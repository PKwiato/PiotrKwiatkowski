---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: "Managing Director | Head of Engineering",
    company: "Pitney Bowes",
    period: "10/2024 - Present",
    focus: "Executive leadership, organizational direction, stakeholder alignment, multi-line strategy.",
    bullets: [
      "Spearheaded cross-functional initiatives that enhanced product delivery efficiency.",
      "Guided organizational change efforts to modernize workflows and technology stacks.",
      "Built and scaled multidisciplinary teams across engineering, QA, and product areas."
    ]
  },
  {
    role: "Engineering Services Manager",
    company: "Pitney Bowes",
    period: "2019 - 2024",
    focus: "Hands-on delivery leadership, technical process improvement, team scaling.",
    bullets: [
      "Led multiple engineering teams focused on internal and external products.",
      "Increased product delivery speed by 30% through agile practices.",
      "Reduced engineering team attrition from 18% to under 8%.",
      "Drove cloud-native adoption (Azure), cutting infrastructure costs by 20%."
    ]
  },
  {
    role: "Senior Software Development Engineer",
    company: "Pitney Bowes",
    period: "2018 - 2019",
    focus: "Hands-on software development, code quality, solution delivery.",
    bullets: [
      "Key role in delivering robust, scalable solutions for global clients.",
      "Developed mission-critical modules for regulated sectors, including US federal.",
      "Promoted SOLID principles, reducing code duplication by 30%."
    ]
  }
];

const achievements = [
  { title: "Enhanced Delivery Speed", desc: "Increased product delivery speed by 30% through agile practices." },
  { title: "Improved Team Retention", desc: "Reduced engineering attrition from 18% to under 8% via clear career paths." },
  { title: "Optimized Infra Costs", desc: "Drove cloud-native adoption, cutting infrastructure costs by 20%." },
  { title: "Expanded Internationally", desc: "Launched products across US, France, Germany, and Japan." }
];

const skills = ["Agile/Scrum", "Azure", "AWS", "Engineering Management", "Clean Code", "CRM", "Cypress", "Git", "ISTQB", "JavaScript", "JIRA", "AngularJS", "Six Sigma", "SQL", ".NET"];

const certifications = ["ITIL4 Foundation", "AgilePM Foundation", "ISTQB® Certified Tester", "Lean Six Sigma Foundations"];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Piotr Kwiatkowski",
  "jobTitle": "Engineering Manager | Managing Director",
  "description": "Engineering Leader with 10+ years of experience building large-scale SaaS and cloud platforms.",
  "url": "https://www.kwiatkowskipiotr.pl",
  "sameAs": [
    "https://linkedin.com/in/piotrkwiatkowski84"
  ],
  "knowsAbout": [
    "Engineering Management",
    "Agile Leadership",
    "DevOps",
    "Cloud Infrastructure",
    "Azure",
    "AWS"
  ],
  "alumniOf": [
    {
      "@type": "CollegeOrUniversity",
      "name": "Warsaw University of Technology"
    },
    {
      "@type": "CollegeOrUniversity",
      "name": "College of Informatics and Management"
    }
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Pitney Bowes"
  }
};
---

<BaseLayout 
  title="Piotr Kwiatkowski | Engineering Manager & Managing Director"
  description="Official portfolio of Piotr Kwiatkowski, a seasoned Engineering Manager and Managing Director with expertise in DevOps, Cloud Infrastructure, and Agile leadership. Explore 10+ years of engineering excellence."
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <!-- Hero Section -->
  <section class="relative px-6 md:px-12 min-h-screen flex items-center justify-center overflow-hidden">
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10 pb-12 lg:pb-0">
      <div class="lg:col-span-7">
        <div class="flex flex-col gap-6">
          <span class="font-space-grotesk text-primary text-[10px] uppercase tracking-[0.4em]">Available for Strategic Leadership</span>
          <h1 class="text-6xl md:text-8xl lg:text-9xl leading-[0.9] -tracking-[0.04em] font-newsreader italic">
            Piotr<br/>Kwiatkowski
          </h1>
          <p class="font-space-grotesk text-lg md:text-2xl text-white/80 max-w-xl leading-snug">
            Engineering Leader with 10+ years of experience building large-scale SaaS and cloud platforms.
          </p>
          <div class="flex flex-wrap gap-4 mt-8">
            <a href="#experience" class="btn-primary inline-flex items-center justify-center min-w-[180px]">View Experience</a>
            <a href="mailto:pkwiatek@gmail.com" class="inline-flex items-center justify-center px-8 py-3 bg-white/5 hover:bg-white/10 transition-colors uppercase font-space-grotesk text-[11px] font-bold tracking-widest border border-outline-variant/20 min-w-[180px]">Contact</a>
          </div>
        </div>
      </div>
      <div class="lg:col-span-5 relative">
        <div class="relative z-10 p-4 bg-surface-container border border-outline-variant/20">
          <img src="/me.png" alt="Piotr Kwiatkowski" class="w-full h-auto max-h-[60vh] object-cover transition-all duration-700" />
        </div>
        <div class="absolute -top-12 -right-12 w-32 h-32 bg-primary/10 -z-10 blur-3xl"></div>
      </div>
    </div>

    <!-- Scroll Indicator Module -->
    <div 
      id="scroll-indicator"
      class="fixed bottom-8 left-6 md:left-12 lg:left-24 flex flex-col items-center gap-4 group cursor-pointer z-50 transition-all duration-500" 
      onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})"
    >
      <div class="flex flex-col items-center gap-3">
        <!-- Mechanical Track -->
        <div class="w-5 h-10 border border-primary/20 relative p-1">
          <div class="w-full bg-primary scroll-slide shadow-[0_0_15px_rgba(255,143,115,0.6)]"></div>
        </div>
        <!-- Technical Label -->
        <div class="flex flex-col items-center gap-1">
          <div class="w-px h-8 bg-primary/20"></div>
          <span class="font-space-grotesk text-[8px] uppercase tracking-[0.4em] text-primary/60 group-hover:text-primary transition-colors">Scroll</span>
        </div>
      </div>
    </div>

    <script is:inline>
      window.addEventListener('scroll', () => {
        const indicator = document.getElementById('scroll-indicator');
        if (indicator) {
          if (window.scrollY > 100) {
            indicator.style.opacity = '0';
            indicator.style.visibility = 'hidden';
            indicator.style.pointerEvents = 'none';
          } else {
            indicator.style.opacity = '1';
            indicator.style.visibility = 'visible';
            indicator.style.pointerEvents = 'auto';
          }
        }
      });
    </script>
  </section>

  <!-- Summary Section -->
  <section class="bg-surface-container-low py-24 px-6 md:px-12 mt-12">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <h2 class="text-4xl md:text-6xl font-newsreader italic leading-tight">
        "I bridge the gap between business vision and engineering excellence."
      </h2>
      <div class="font-space-grotesk text-white/60 leading-relaxed text-sm md:text-base space-y-4">
        <p>
          I moved into leadership because I enjoy helping teams do their best work and ensuring technology supports real business needs. I've led international projects, built strong teams, and reduced staff turnover to single digits.
        </p>
        <p>
          I care about writing clean, reliable code, designing systems that scale well, and keeping the focus on outcomes that matter.
        </p>
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="py-24 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <h2 class="text-5xl md:text-7xl font-newsreader italic">Technical<br/>Trajectory</h2>
        <span class="text-outline-variant text-[10px] uppercase tracking-[0.3em] font-space-grotesk pb-4">Pitney Bowes // 2009—2024+</span>
      </div>

      <div class="space-y-4">
        {experience.map((job) => (
          <div class="group bg-surface-container/20 hover:bg-surface-container/60 transition-colors duration-500 p-8 md:p-12">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
              <div class="lg:col-span-4">
                <span class="font-space-grotesk text-[10px] text-primary tracking-widest uppercase mb-2 block">{job.period}</span>
                <h3 class="text-2xl md:text-3xl font-newsreader italic mb-1">{job.role}</h3>
                <span class="text-outline-variant font-space-grotesk text-sm">{job.company}</span>
              </div>
              <div class="lg:col-span-8 font-space-grotesk">
                <p class="text-white/80 mb-6 text-sm italic border-l-2 border-primary/40 pl-4">{job.focus}</p>
                <ul class="space-y-3 text-white/60 text-sm">
                  {job.bullets.map(bullet => (
                    <li class="flex gap-4">
                      <span class="text-primary mt-1.5">•</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Achievements Section -->
  <section id="achievements" class="bg-surface-container py-24 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-4xl md:text-6xl font-newsreader italic mb-16">High-Voltage<br/>Impact</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {achievements.map(item => (
          <div class="bg-surface-bright p-8 border border-white/5 group hover:border-primary/40 transition-colors">
            <div class="h-1 w-8 bg-primary mb-6 transition-all group-hover:w-16"></div>
            <h3 class="font-newsreader text-xl italic mb-4">{item.title}</h3>
            <p class="font-space-grotesk text-xs text-white/50 leading-relaxed uppercase tracking-wider">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills & Certs Section -->
  <section id="skills" class="py-24 px-6 md:px-12">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-7">
        <h2 class="text-4xl md:text-6xl font-newsreader italic mb-12">Machine<br/>Capabilities</h2>
        <div class="flex flex-wrap gap-2">
          {skills.map(skill => (
            <span class="mx-chip hover:bg-primary hover:text-on-primary cursor-default transition-colors">{skill}</span>
          ))}
        </div>
      </div>
      <div class="lg:col-span-5">
        <h2 class="text-4xl md:text-6xl font-newsreader italic mb-12">Verified<br/>Standards</h2>
        <div class="space-y-2">
          {certifications.map(cert => (
            <div class="bg-surface-container-low p-4 flex justify-between items-center group overflow-hidden relative">
              <span class="font-space-grotesk text-xs uppercase tracking-widest relative z-10">{cert}</span>
              <div class="h-px w-0 bg-primary/20 absolute bottom-0 left-0 transition-all duration-700 group-hover:w-full"></div>
            </div>
          ))}
        </div>
        
        <div class="mt-16 p-8 border-t border-outline-variant/20 bg-surface-container/10">
          <h3 class="font-newsreader italic text-xl mb-4">Education</h3>
          <div class="space-y-6">
            <div>
              <span class="text-[10px] text-primary uppercase font-space-grotesk">2022 - 2023</span>
              <p class="font-space-grotesk text-sm uppercase tracking-wider">Warsaw University of Technology</p>
              <p class="text-white/40 text-xs italic">IT Resource Management: Postgraduate Studies</p>
            </div>
            <div>
              <span class="text-[10px] text-primary uppercase font-space-grotesk">2007 - 2009</span>
              <p class="font-space-grotesk text-sm uppercase tracking-wider">College of Informatics and Management</p>
              <p class="text-white/40 text-xs italic">Master of Engineering: Computer Science</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
